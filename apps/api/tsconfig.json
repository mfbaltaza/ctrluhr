{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["bun"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@ctrluhr/schema": ["../../packages/schema/src/index.ts"],
      "@ctrluhr/schema/*": ["../../packages/schema/src/*"]
    }
  },
  "include": ["src/**/*", "migrations/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}
