{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "strict": true,
    "types": ["bun"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@ctrluhr/schema": ["../../packages/schema/src/index.ts"],
      "@ctrluhr/schema/*": ["../../packages/schema/src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*", "migrations/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
